{
	"include": ["src/**/*", "__tests__/**/*", "tests/**/*", "vitest.config.ts"],
	"exclude": ["node_modules/*"],
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"sourceMap": true,
		"strict": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["node", "svelte", "vitest"],
		"lib": ["DOM", "ES2020"],
		"baseUrl": ".",
		"paths": {
			"src": ["src"],
			"src/*": ["src/*"]
		}
	}
}
